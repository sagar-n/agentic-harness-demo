# Agentic Harness Demo — Environment Configuration
# Copy this file to .env and customize.

# ── Ollama ──────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
REASONING_MODEL=qwen3:14b
VISION_MODEL=qwen2.5-vl:7b
FAST_MODEL=qwen3:4b

# ── Browser ─────────────────────────────────────────────────────────
BROWSER_HEADLESS=true
TRADINGVIEW_URL=https://www.tradingview.com

# ── Confidence & Retry ──────────────────────────────────────────────
MIN_CONFIDENCE_THRESHOLD=0.6
MAX_RETRIES=2

# ── API ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Langfuse (optional) ─────────────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ── oMLX (optional OpenAI-compatible endpoint) ──────────────────────
OMLX_ENABLED=false
OMLX_BASE_URL=http://localhost:8000
OMLX_API_KEY=your-omlx-api-key-here

# ── Storage ─────────────────────────────────────────────────────────
# DATA_DIR=~/.trademind
